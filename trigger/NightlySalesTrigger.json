{
    "name": "NightlySalesTrigger",
    "properties": {
        "type": "ScheduleTrigger",
        "description": "Fires the master orchestration pipeline every night at 01:00 UTC. Passes the current date as the run date.",
        "typeProperties": {
            "recurrence": {
                "frequency": "Day",
                "interval": 1,
                "startTime": "2024-01-01T01:00:00Z",
                "timeZone": "UTC",
                "schedule": {
                    "hours": [1],
                    "minutes": [0]
                }
            }
        },
        "pipelines": [
            {
                "pipelineReference": {
                    "referenceName": "MasterOrchestrationPipeline",
                    "type": "PipelineReference"
                },
                "parameters": {
                    "runDate": { "value": "@formatDateTime(trigger().scheduledTime, 'yyyy-MM-dd')", "type": "Expression" }
                }
            }
        ],
        "annotations": ["scheduled", "nightly", "production"]
    }
}
